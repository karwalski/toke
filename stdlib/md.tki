{
  "schema_version": "1.0",
  "module": "std.md",
  "exports": [
    {"kind": "func", "name": "md.render",     "params": ["str"],  "return": "str"},
    {"kind": "func", "name": "md.renderfile", "params": ["str"],  "return": "str!MdErr"},
    {"kind": "record", "name": "MdErr",       "fields": [{"name": "msg", "type": "str"}]}
  ]
