m=sseservertest;




f=countstream(ctx:$ssectx):void{
  sse.keepalive(ctx;15000);
  let i:u64=0;
  lp(let lv=0;true;lv=lv){
    if(i=10){break};
    let ev=$sseevent{
      id:str.fromu64(i);
      event:"tick";
      data:str.fromu64(i);
      retry:3000
    };
    let result=sse.emit(ctx;ev);
    (match result{
      ok(){};
      err(e){
        (log.error(str.concat("sse emit error: ";e.msg)));
        break;
      };
    });
    set i=i+1;
  };
  sse.close(ctx);
};


f=logtail(ctx:$ssectx;lines:@$str):void{
  sse.keepalive(ctx;10000);
  let i:u64=0;
  lp(let lv=0;true;lv=lv){
    if(i=lines.len){break};
    let line=lines.get(i);
    let result=sse.emitdata(ctx;line);
    (match result{
      ok(){};
      err(){break};
    });
    set i=i+1;
  };
  sse.close(ctx);
};


f=tokenstream(ctx:$ssectx;tokens:@$str):void{
  sse.keepalive(ctx;20000);
  let i:u64=0;
  lp(let lv=0;true;lv=lv){
    if(i=tokens.len){break};
    let tok=tokens.get(i);
    let result=sse.emitdata(ctx;tok);
    (match result{
      ok(){};
      err(e){
        (log.warn(str.concat("token stream interrupted: ";e.msg)));
        sse.close(ctx);
        <void
      };
    });
    set i=i+1;
  };
  let done=$sseevent{
    id:"";
    event:"done";
    data:"";
    retry:0
  };
  let  = sse.emit(ctx;done);
  sse.close(ctx);
};


f=chartfeed(ctx:$ssectx;points:@$str):void{
  sse.keepalive(ctx;5000);
  let i:u64=0;
  lp(let lv=0;true;lv=lv){
    if(i=points.len){break};
    let ev=$sseevent{
      id:str.fromu64(i);
      event:"datapoint";
      data:points.get(i);
      retry:2000
    };
    let result=sse.emit(ctx;ev);
    (match result{
      ok(){};
      err(){break};
    });
    set i=i+1;
  };
  sse.close(ctx);
};


f=testeventfields():bool{
  let ev=$sseevent{id:"42";event:"update";data:"hello";retry:1000};
  (test.ok(ev.id="42"));
  (test.ok(ev.event="update"));
  (test.ok(ev.data="hello"));
  (test.eq(ev.retry;1000));
  <true
};

f=testctxfields():bool{
  let ctx=$ssectx{id:7;open:true};
  (test.eq(ctx.id;7));
  (test.ok(ctx.open));
  <true
};

f=main():i64{
  (test.ok(testeventfields()));
  (test.ok(testctxfields()));
  <0
};
