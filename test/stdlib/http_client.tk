m=httpclienttest;




f=fetchuser(id:u64):$str!$httperr{
  let c=http.client("https://api.example.com");
  let path=str.concat("/users/";str.fromu64(id));
  let resp=http.get(c;path);
  let bodystr=str.frombytes(resp.body);
  let j=json.dec(bodystr);
  <json.str(j;"name")
};


f=createuser(name:$str;email:$str):u64!$httperr{
  let c=http.client("https://api.example.com");
  let payload=str.concat(
    str.concat("{\"name\":\"";name);
    str.concat("\";\"email\":\"";str.concat(email;"\"}"))
  );
  let body=str.bytes(payload);
  let resp=http.post(c;"/users";body;"application/json");
  if(resp.status!=201){
    <err($httperr{msg:"unexpected status";code:resp.status})
  };
  let j=json.dec(str.frombytes(resp.body));
  <json.u64(j;"id")
};


f=updateuser(id:u64;name:$str):void!$httperr{
  let c=http.client("https://api.example.com");
  let path=str.concat("/users/";str.fromu64(id));
  let payload=str.concat("{\"name\":\"";str.concat(name;"\"}"));
  let resp=http.put(c;path;str.bytes(payload);"application/json");
  if(resp.status!=200){
    <err($httperr{msg:"put failed";code:resp.status})
  };
  <ok(void)
};


f=deleteuser(id:u64):void!$httperr{
  let c=http.client("https://api.example.com");
  let path=str.concat("/users/";str.fromu64(id));
  let resp=http.delete(c;path);
  if(resp.status!=204){
    <err($httperr{msg:"delete failed";code:resp.status})
  };
  <ok(void)
};


f=streamdownload(url:$str):@$byte!$httperr{
  let c=http.client(url);
  let req=$httpreq{
    method:"GET";
    url:"/download";
    headers:@();
    body:@()
  };
  let s=http.stream(c;req);
  let buf:@$byte=@();
  let running:bool=true;
  lp(let lv=0;true;lv=lv){
    if(!$running){break};
    let chunk=http.streamnext(s);
    (match chunk{
      ok(bytes){
        if(bytes.len=0){
          set running=false;
        }el{
          set buf=buf+bytes;
        };
      };
      err(e){
        if(e.code=0){
          set running=false;
        }el{
          <err(e)
        };
      };
    });
  };
  <ok(buf)
};


f=testclientconstruct():bool{
  let c=http.client("https://httpbin.org");
  <c.baseurl="https://httpbin.org"
};

f=main():i64{
  (test.ok(testclientconstruct()));
  <0
};
