m=encodingtest;
i=enc:std.encoding;


f=testb64roundtrip():bool{
  let data=@(72;101;108;108;111);
  let encoded=enc.b64encode(data);
  let decoded=enc.b64decode(encoded)!i64$encodingerr;
  <decoded.len()=data.len()
};


f=testb64urlroundtrip():bool{
  let data=@(72;101;108;108;111);
  let encoded=enc.b64urlencode(data);
  let decoded=enc.b64urldecode(encoded)!i64$encodingerr;
  <decoded.len()=data.len()
};


f=testhexroundtrip():bool{
  let data=@(222;173;190;239);
  let encoded=enc.hexencode(data);
  let decoded=enc.hexdecode(encoded)!i64$encodingerr;
  <decoded.len()=data.len()
};


f=testhexlowercase():bool{
  let data=@(255;0;171);
  let encoded=enc.hexencode(data);
  <encoded="ff00ab"
};


f=testurlroundtrip():bool{
  let s="hello world+foo=bar&baz";
  let encoded=enc.urlencode(s);
  let decoded=enc.urldecode(encoded)!i64$encodingerr;
  <decoded=s
};


f=testb64urlnopadding():bool{
  let data=@(1;2;3);
  let encoded=enc.b64urlencode(data);
  let haspad=str.contains(encoded;"=");
  <haspad=false
};

f=main():i64{
  let r0=testb64roundtrip();
  let r1=testb64urlroundtrip();
  let r2=testhexroundtrip();
  let r3=testhexlowercase();
  let r4=testurlroundtrip();
  let r5=testb64urlnopadding();
  if(r0&&r1&&r2&&r3&&r4&&r5){
    <0
  }el{
    <1
  }
};
