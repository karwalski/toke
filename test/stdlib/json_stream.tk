m=jsonstreamtest;



f=sumcounts(input:@$byte):i64!$jsonstreamerr{
  let parser=$streamparser(input);
  let total:i64=0;
  let inarray:bool=false;
  let inobject:bool=false;
  let wantcount:bool=false;
  let running:bool=true;
  lp(let lv=0;true;lv=lv){
    if(!$running){break};
    let tok=json.streamnext(parser);
    if(tok=$$arraystart){
      set inarray=true;
    };
    if(tok=$$objectstart){
      set inobject=true;
    };
    if(tok=$$objectend){
      set inobject=false;
      set wantcount=false;
    };
    if(tok=$$arrayend){
      set inarray=false;
      set running=false;
    };
    if(tok=$$key){
      if(tok.$key="count"){
        set wantcount=true;
      };
    };
    if(tok=$u64){
      if(wantcount){
        set total=total+tok.u64:i64;
        set wantcount=false;
      };
    };
    if(tok=$$end){
      set running=false;
    };
  };
  <total
};

f=main():i64{
  let data=str.bytes("[{\"id\":1;\"count\":10};{\"id\":2;\"count\":25};{\"id\":3;\"count\":5}]");
  let result=sumcounts(data);
  (match result{
    ok(n){
      (test.eq(n;40));
      <0
    };
    err(e){
      (log.error("stream parse failed"));
      <1
    };
  })
};
