m=analyticstest;
i=df:std.dataframe;
i=analytics:std.analytics;
i=test:std.test;
i=str:std.str;


f=makeframe():$dataframe{
  let data=str.bytes("group,value,ts
A,10,1
A,20,2
B,30,3
B,40,4
A,15,5
");
  let result=df.fromcsv(data);
  (match result{
    ok(frame){<frame};
    err(e){
      (test.fail(e.msg));
      <df.head(df.fromcsv(str.bytes("g,v,t
0,0,0
")).ok;0)
    };
  })
};


f=describetest():bool{
  let frame=makeframe();
  let result=analytics.describe(frame);
  (match result{
    ok(rows){
      
      <(rows.len>0)
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=groupstatstest():bool{
  let frame=makeframe();
  let result=analytics.groupstats(frame;"group";"value");
  (match result{
    ok(stats){
      
      (test.eq(stats.len;2));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=timeseriestest():bool{
  let frame=makeframe();
  let result=analytics.timeseries(frame;"ts";"value";2);
  (match result{
    ok(pts){
      (test.eq(pts.len;5));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=anomaliestest():bool{
  let data=str.bytes("v
1
2
3
4
5
");
  let result=df.fromcsv(data);
  (match result{
    ok(frame){
      let anom=analytics.anomalies(frame;"v";2.0);
      (match anom{
        ok(idxs){
          <(idxs.len=0)
        };
        err(e){
          (test.fail(e.msg));
          <false
        };
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=corrtest():bool{
  let data=str.bytes("x,y
1,2
2,4
3,6
4,8
");
  let result=df.fromcsv(data);
  (match result{
    ok(frame){
      let r=analytics.corr(frame;"x";"y");
      (match r{
        ok(c){
          <(c>0.99)
        };
        err(e){
          (test.fail(e.msg));
          <false
        };
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};

f=main():i64{
  (test.ok(describetest()));
  (test.ok(groupstatstest()));
  (test.ok(timeseriestest()));
  (test.ok(anomaliestest()));
  (test.ok(corrtest()));
  <0
};
