m=authjwt;
i=auth:std.auth;
i=enc:std.encoding;
i=time:std.time;


f=testjwtsignverify():bool!i64$autherr{
  let secret=@(115;101;99;114;101;116);
  let now=time.now();
  let claims=$$jwtclaims{
    sub:"user-42";
    iss:"myapp";
    exp:now+3600;
    iat:now;
    extra:@()
  };
  let token=auth.jwtsign(claims;secret;$$$hs256)!i64$autherr;
  let verified=auth.jwtverify(token;secret)!i64$autherr;
  let expired=auth.jwtexpired(verified);
  <verified.sub="user-42"&&expired=false
};


f=testjwtexpired():bool!i64$autherr{
  let secret=@(115;101;99;114;101;116);
  let past=time.now()-7200;
  let claims=$$jwtclaims{
    sub:"user-1";
    iss:"myapp";
    exp:past;
    iat:past;
    extra:@()
  };
  let token=auth.jwtsign(claims;secret;$$$hs256)!i64$autherr;
  let verified=auth.jwtverify(token;secret)!i64$autherr;
  <auth.jwtexpired(verified)=true
};


f=testbearerextract():bool!i64$autherr{
  let header="Bearer eyJhbGciOiJIUzI1NiJ9.test.sig";
  let token=auth.bearerextract(header)!i64$autherr;
  <token="eyJhbGciOiJIUzI1NiJ9.test.sig"
};


f=testapikey():bool!i64$autherr{
  let key=auth.apikeygenerate("sk");
  let store=$$keystore{handle:0};
  let valid=auth.apikeyvalidate(key;store)!i64$autherr;
  <valid=true
};

f=main():i64{
  let r0=testjwtsignverify()!i64$autherr;
  let r1=testjwtexpired()!i64$autherr;
  let r2=testbearerextract()!i64$autherr;
  if(r0&&r1&&r2){
    <0
  }el{
    <1
  }
};
