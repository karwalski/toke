m=dataframetest;
i=df:std.dataframe;
i=test:std.test;
i=str:std.str;


f=fromcsvshape():bool{
  let data=str.bytes("name,age,score
alice,30,95.5
bob,25,82.0
carol,28,88.0
");
  let result=df.fromcsv(data);
  (match result{
    ok(frame){
      let s=df.shape(frame);
      (test.eq(s.rows;3));
      (test.eq(s.cols;3));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=columnnumeric():bool{
  let data=str.bytes("x,y
1,10
2,20
3,30
");
  let result=df.fromcsv(data);
  (match result{
    ok(frame){
      let colresult=df.column(frame;"y");
      (match colresult{
        ok(vals){
          (test.eq(vals.len;3));
          (test.eq(vals.get(0);10.0));
          (test.eq(vals.get(2);30.0));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        };
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=filtergt():bool{
  let data=str.bytes("name,score
alice,95
bob,70
carol,88
");
  let result=df.fromcsv(data);
  (match result{
    ok(frame){
      let filtered=df.filter(frame;"score";"gt";"85");
      (match filtered{
        ok(f2){
          let s=df.shape(f2);
          (test.eq(s.rows;2));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        };
      })
    };
    err(e){
      (test.fail(e.msg));
