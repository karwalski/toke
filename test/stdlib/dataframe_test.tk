f=headrows():bool{
  let data=str.bytes("id,val
1,a
2,b
3,c
4,d
5,e
");
  let result=df.fromcsv(data);
  (match result{
    ok(frame){
      let h=df.head(frame;2);
      let s=df.shape(h);
      (test.eq(s.rows;2));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=schemacheck():bool{
  let data=str.bytes("a,b,c
1,2,3
");
  let result=df.fromcsv(data);
  (match result{
    ok(frame){
      let cols=df.schema(frame);
      (test.eq(cols.len;3));
      (test.eq(cols.get(0).name;"a"));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};

f=main():i64{
  (test.ok(fromcsvshape()));
  (test.ok(columnnumeric()));
  (test.ok(filtergt()));
  (test.ok(headrows()));
  (test.ok(schemacheck()));
  <0
};
