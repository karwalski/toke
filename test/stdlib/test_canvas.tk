m=canvastest;



f=newsmoke():bool{
  let c=canvas.new("smoke"; 200; 100);
  <c.id="smoke" && c.width=200 && c.height=100 && c.ops.len=0
};

f=fillrectsmoke():bool{
  let c=canvas.new("r"; 400; 300);
  let c=canvas.fillrect(c;0.0;0.0;400.0;300.0;"#ff0000");
  <c.ops.len=1
};

f=strokerectsmoke():bool{
  let c=canvas.new("r"; 400; 300);
  let c=canvas.strokerect(c;10.0;10.0;100.0;50.0;"#0000ff";2.0);
  <c.ops.len=1
};

f=clearrectsmoke():bool{
  let c=canvas.new("r"; 400; 300);
  let c=canvas.fillrect(c;0.0;0.0;400.0;300.0;"#ffffff");
  let c=canvas.clearrect(c;0.0;0.0;400.0;300.0);
  <c.ops.len=2
};

f=filltextsmoke():bool{
  let c=canvas.new("t"; 320; 240);
  let c=canvas.filltext(c;"Hello Canvas";10.0;30.0;"16px sans-serif";"#111111");
  <c.ops.len=1
};

f=pathsmoke():bool{
  
  let c=canvas.new("path"; 300; 300);
  let c=canvas.beginpath(c);
  let c=canvas.moveto(c;50.0;50.0);
  let c=canvas.lineto(c;250.0;50.0);
  let c=canvas.lineto(c;150.0;230.0);
  let c=canvas.closepath(c);
  let c=canvas.stroke(c;"#e74c3c";3.0);
  <c.ops.len=6
};

f=arcfillsmoke():bool{
  let pi=3.141592653589793;
  let c=canvas.new("arc"; 200; 200);
  let c=canvas.beginpath(c);
  let c=canvas.arc(c;100.0;100.0;60.0;0.0;pi*2.0);
  let c=canvas.fill(c;"#2ecc71");
  <c.ops.len=3
};

f=drawimagesmoke():bool{
  let c=canvas.new("img"; 640; 480);
  let c=canvas.drawimage(c;"https://example.com/logo.png";0.0;0.0;64.0;64.0);
  <c.ops.len=1
};

f=setalphasmoke():bool{
  let c=canvas.new("alpha"; 100; 100);
  let c=canvas.setalpha(c;0.5);
  let c=canvas.fillrect(c;0.0;0.0;100.0;100.0;"#000000");
  let c=canvas.setalpha(c;1.0);
  <c.ops.len=3
};

f=opsaccumulate():bool{
  
  let c=canvas.new("acc"; 500; 500);
  let c=canvas.fillrect(c;0.0;0.0;500.0;500.0;"#f0f0f0");
  let c=canvas.beginpath(c);
  let c=canvas.moveto(c;10.0;10.0);
  let c=canvas.lineto(c;490.0;490.0);
  let c=canvas.stroke(c;"#333333";1.0);
  <c.ops.len=5
};

f=tojssmoke():bool{
  let c=canvas.new("js"; 300; 200);
  let c=canvas.fillrect(c;0.0;0.0;300.0;200.0;"#abcdef");
  let js=canvas.tojs(c);
  
  <js.len>0 && str.contains(js;"js")
};

f=tohtmlsmoke():bool{
  let c=canvas.new("html_out"; 480; 270);
  let c=canvas.fillrect(c;0.0;0.0;480.0;270.0;"#1a1a2e");
  let c=canvas.filltext(c;"Toke Canvas";40.0;50.0;"bold 22px monospace";"#e0e0e0");
  let frag=canvas.tohtml(c);
  
  <str.contains(frag;"<canvas") && str.contains(frag;"<script")
};

f=htmlintegrationsmoke():bool{
  
  let c=canvas.new("embed"; 640; 480);
  let c=canvas.fillrect(c;0.0;0.0;640.0;480.0;"#ffffff");
  let c=canvas.filltext(c;"Embedded";20.0;40.0;"18px sans-serif";"#000000");
  let js=canvas.tojs(c);
  let d=html.doc();
  html.title(d;"Canvas Integration");
  html.script(d;js);
  let out=html.render(d);
  <str.contains(out;"<canvas") || str.contains(out;"getContext")
};

f=main():i64{
  (test.ok(newsmoke()));
  (test.ok(fillrectsmoke()));
  (test.ok(strokerectsmoke()));
  (test.ok(clearrectsmoke()));
  (test.ok(filltextsmoke()));
  (test.ok(pathsmoke()));
  (test.ok(arcfillsmoke()));
  (test.ok(drawimagesmoke()));
  (test.ok(setalphasmoke()));
  (test.ok(opsaccumulate()));
  (test.ok(tojssmoke()));
  (test.ok(tohtmlsmoke()));
  (test.ok(htmlintegrationsmoke()));
  <0
};
