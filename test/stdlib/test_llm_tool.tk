m=llmtooltest;



f=maketool():$tooldecl{
  let p1=$toolparam{name:"city";type:"str";desc:"The city name";required:true};
  let p2=$toolparam{name:"units";type:"str";desc:"celsius or fahrenheit";required:false};
  <$tooldecl{
    name:"get_weather";
    desc:"Returns current weather for a city";
    params:@(p1;p2)
  }
};

f=makeresult(callid:$str):$toolresult{
  <$toolresult{id:callid;content:"{\"temp\":22;\"desc\":\"sunny\"}";error:false}
};

f=main():i64{
  let tool=maketool();
  (test.ok(tool.name="get_weather"));
  (test.eq(tool.params.len;2));
  (test.ok(tool.params.get(0).required));
  (test.ok(!$tool.params.get(1).required));

  let result=makeresult("call-abc123");
  (test.ok(result.id="call-abc123"));
  (test.ok(!$result.error));

  
  let tc=$toolcall{
    name:"get_weather";
    args:@(@("city";"London");@("units";"celsius"));
    id:"call-abc123"
  };
  (test.ok(tc.name="get_weather"));
  (test.ok(tc.id="call-abc123"));

  <0
};
