m=dashboardtest;



f=builddashboard():$dashboard{
  let d=dashboard.new("System Monitor";8080);
  <d
};

f=addwidgets():bool{
  let d=dashboard.new("Test Dashboard";9090);

  
  let spec=chart.bar(
    @("cpu";"mem";"disk");
    @(42.0;67.3;15.8);
    "Resource Usage"
  );
  let w1=dashboard.addchart(d;"resources";spec);
  (test.ok(w1.id="resources"));

  
  let w2=dashboard.addtable(d;"requests";@("Method";"Path";"Status";"Latency"));
  (test.ok(w2.id="requests"));

  
  let rowjson=str.bytes("[\"GET\";\"/ \";\"200\";\"12ms\"]");
  dashboard.update(d;w2;rowjson);

  <true
};

f=main():i64{
  let d=builddashboard();
  
  (test.ok(true));
  (test.ok(addwidgets()));
  <0
};
