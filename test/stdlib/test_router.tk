m=routertest;



f=buildrouter():$router{
  let r=router.new();
  
  let h:$handler=$handler{id:1};
  router.get(r;"/";h);
  router.get(r;"/items/:id";h);

  
  let ph:$handler=$handler{id:2};
  router.post(r;"/items";ph);

  
  let uh:$handler=$handler{id:3};
  router.put(r;"/items/:id";uh);
  let dh:$handler=$handler{id:4};
  router.delete(r;"/items/:id";dh);

  
  let mw:$middleware=$middleware{id:10};
  router.use(r;mw);

  <r
};

f=main():i64{
  let r=buildrouter();
  
  (test.ok(true));
  <0
};
