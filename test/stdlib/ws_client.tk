m=wsclienttest;




f=echoroundtrip(url:$str):bool!$wserr{
  let conn=ws.connect(url);
  ws.send(conn;"hello");
  let msg=ws.recv(conn);
  let body=str.frombytes(msg.payload);
  ws.close(conn);
  <ok(body="hello")
};


f=binaryroundtrip(url:$str;data:@$byte):bool!$wserr{
  let conn=ws.connect(url);
  ws.sendbytes(conn;data);
  let reply=ws.recv(conn);
  ws.close(conn);
  <ok(reply.payload.len=data.len)
};


f=recvlp(let lv=0;true;lv=lv)(url:$str):i64!$wserr{
  let conn=ws.connect(url);
  let count:i64=0;
  let running:bool=true;
  lp(let lv=0;true;lv=lv){
    if(!$running){break};
    let msg=ws.recv(conn);
    if(msg.opcode=8){
      set running=false;
    }el{
      set count=count+1;
    };
  };
  ws.close(conn);
  <ok(count)
};


f=notifyall(conns:@$wsconn;status:$str):void{
  let payload=str.concat("{\"status\":\"";str.concat(status;"\"}"));
  ws.broadcast(conns;payload);
};


f=testconnready(url:$str):bool!$wserr{
  let conn=ws.connect(url);
  let ready=conn.ready;
  ws.close(conn);
  <ok(ready)
};

f=main():i64{
  
  let dummy=$wsconn{id:0;ready:false};
  (test.eq(dummy.id;0));
  let msg=$wsmsg{payload:@();fin:true;opcode:1};
  (test.ok(msg.fin));
  <0
};
