m=testencrypt;
i=enc:std.encrypt;
i=cry:std.crypto;


f=testkeygenlen():bool{
  let key=enc.aes256gcmkeygen();
  let expected:u64=32;
  (test.eq(key.len;expected));
  <true
};


f=testnoncegenlen():bool{
  let nonce=enc.aes256gcmnoncegen();
  let expected:u64=12;
  (test.eq(nonce.len;expected));
  <true
};


f=testaesroundtrip():bool{
  let key=enc.aes256gcmkeygen();
  let nonce=enc.aes256gcmnoncegen();
  let plain=str.bytes("hello encrypt world");
  let aad=str.bytes("v1");
  let ct=enc.aes256gcmencrypt(key;nonce;plain;aad);
  
  let expectedctlen:u64=plain.len+16;
  (test.eq(ct.len;expectedctlen));
  let result=enc.aes256gcmdecrypt(key;nonce;ct;aad);
  (test.eq(result.err;""));
  (test.eq(result.ok.len;plain.len));
  <true
};


f=testaeswrongkey():bool{
  let key=enc.aes256gcmkeygen();
  let badkey=enc.aes256gcmkeygen();
  let nonce=enc.aes256gcmnoncegen();
  let plain=str.bytes("secret data");
  let ct=enc.aes256gcmencrypt(key;nonce;plain;@());
  let result=enc.aes256gcmdecrypt(badkey;nonce;ct;@());
  
  <result.err!=""
};


f=testaestamper():bool{
  let key=enc.aes256gcmkeygen();
  let nonce=enc.aes256gcmnoncegen();
  let plain=str.bytes("tamper test");
  let ct=enc.aes256gcmencrypt(key;nonce;plain;@());
  
  let badct=@(ct.slice(0;1);@(255);ct.slice(2;ct.len));
  let result=enc.aes256gcmdecrypt(key;nonce;badct;@());
  <result.err!=""
};


f=testx25519keypairlen():bool{
  let kp=enc.x25519keypair();
  let expected:u64=32;
  (test.eq(kp.pubkey.len;expected));
  (test.eq(kp.privkey.len;expected));
  <true
};


f=testx25519dhsymmetric():bool{
  let alice=enc.x25519keypair();
  let bob=enc.x25519keypair();
  let shareda=enc.x25519dh(alice.privkey;bob.pubkey);
  let sharedb=enc.x25519dh(bob.privkey;alice.pubkey);
  let expected:u64=32;
  (test.eq(shareda.len;expected));
  <cry.constanteq(shareda;sharedb)
};


f=testx25519dhdistinct():bool{
  let alice=enc.x25519keypair();
  let bob=enc.x25519keypair();
  let carol=enc.x25519keypair();
  let sab=enc.x25519dh(alice.privkey;bob.pubkey);
  let sac=enc.x25519dh(alice.privkey;carol.pubkey);
  <(!$cry.constanteq(sab;sac))
};


f=tested25519keypairlen():bool{
  let kp=enc.ed25519keypair();
  let expectedpub:u64=32;
  let expectedpriv:u64=64;
  (test.eq(kp.pubkey.len;expectedpub));
  (test.eq(kp.privkey.len;expectedpriv));
  <true
};


f=tested25519signlen():bool{
  let kp=enc.ed25519keypair();
  let msg=str.bytes("sign me");
  let sig=enc.ed25519sign(kp.privkey;msg);
  let expected:u64=64;
  (test.eq(sig.len;expected));
  <true
};


f=tested25519verifyok():bool{
  let kp=enc.ed25519keypair();
  let msg=str.bytes("authenticate this message");
  let sig=enc.ed25519sign(kp.privkey;msg);
  <enc.ed25519verify(kp.pubkey;msg;sig)
};


f=tested25519verifytamper():bool{
  let kp=enc.ed25519keypair();
  let msg=str.bytes("original message");
  let sig=enc.ed25519sign(kp.privkey;msg);
  let badmsg=str.bytes("tampered message");
  <(!$enc.ed25519verify(kp.pubkey;badmsg;sig))
};


f=tested25519verifywrongkey():bool{
  let kp=enc.ed25519keypair();
  let other=enc.ed25519keypair();
  let msg=str.bytes("message");
  let sig=enc.ed25519sign(kp.privkey;msg);
  <(!$enc.ed25519verify(other.pubkey;msg;sig))
};


f=testhkdflen():bool{
  let ikm=str.bytes("input key material");
  let salt=str.bytes("salt");
  let info=str.bytes("context");
  let n:u64=32;
  let out=enc.hkdfsha256(ikm;salt;info;n);
  (test.eq(out.len;n));
  <true
};


f=testhkdfinfoseparation():bool{
  let ikm=str.bytes("shared-secret");
  let salt=@();
  let outa=enc.hkdfsha256(ikm;salt;str.bytes("use-a");32);
  let outb=enc.hkdfsha256(ikm;salt;str.bytes("use-b");32);
  <(!$cry.constanteq(outa;outb))
};


f=testhkdflong():bool{
  let ikm=str.bytes("seed");
  let out=enc.hkdfsha256(ikm;@();@();64);
  let expected:u64=64;
  (test.eq(out.len;expected));
  <true
};


f=testtlsfingerprintlen():bool{
  
  let pem="-----BEGIN CERTIFICATE-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA0000000000000000000
-----END CERTIFICATE-----";
  let fp=enc.tlscertfingerprint(pem);
  let expected:u64=32;
  (test.eq(fp.len;expected));
  <true
};


f=testfulle2e():bool{
  let alice=enc.x25519keypair();
  let bob=enc.x25519keypair();
  
  let raw=enc.x25519dh(alice.privkey;bob.pubkey);
  let key=enc.hkdfsha256(raw;@();str.bytes("session-key-v1");32);
  let nonce=enc.aes256gcmnoncegen();
  let plain=str.bytes("end to end secret");
  let ct=enc.aes256gcmencrypt(key;nonce;plain;@());
  
  let rawb=enc.x25519dh(bob.privkey;alice.pubkey);
  let keyb=enc.hkdfsha256(rawb;@();str.bytes("session-key-v1");32);
  let result=enc.aes256gcmdecrypt(keyb;nonce;ct;@());
  (test.eq(result.err;""));
  <cry.constanteq(result.ok;plain)
};

f=main():i64{
  (test.ok(testkeygenlen()));
  (test.ok(testnoncegenlen()));
  (test.ok(testaesroundtrip()));
  (test.ok(testaeswrongkey()));
  (test.ok(testaestamper()));
  (test.ok(testx25519keypairlen()));
  (test.ok(testx25519dhsymmetric()));
  (test.ok(testx25519dhdistinct()));
  (test.ok(tested25519keypairlen()));
  (test.ok(tested25519signlen()));
  (test.ok(tested25519verifyok()));
  (test.ok(tested25519verifytamper()));
  (test.ok(tested25519verifywrongkey()));
  (test.ok(testhkdflen()));
  (test.ok(testhkdfinfoseparation()));
  (test.ok(testhkdflong()));
  (test.ok(testtlsfingerprintlen()));
  (test.ok(testfulle2e()));
  <0
};
