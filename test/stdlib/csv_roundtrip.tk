m=csvroundtriptest;
i=csv:std.csv;
i=test:std.test;
i=str:std.str;


f=roundtrip():bool{
  let w=csv.writer(44);
  (csv.writerow(w;@("name";"score";"grade")));
  (csv.writerow(w;@("alice";"95";"A")));
  (csv.writerow(w;@("bob";"82";"B")));
  let bytes=csv.flush(w);
  let result=csv.parse(bytes);
  (match result{
    ok(rows){
      (test.eq(rows.len;3));
      let hdr=rows.get(0);
      (test.eq(hdr.fields.get(0);"name"));
      (test.eq(hdr.fields.get(1);"score"));
      let r1=rows.get(1);
      (test.eq(r1.fields.get(0);"alice"));
      (test.eq(r1.fields.get(2);"A"));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=streaming():bool{
  let data=str.bytes("id,val
1,10
2,20
3,30
");
  let r=csv.reader(data;44);
  let hdrresult=csv.header(r);
  (match hdrresult{
    ok(h){
      (test.eq(h.len;2));
      (test.eq(h.get(0);"id"));
    };
    err(e){
      (test.fail(e.msg));
    };
  });
  let row1=csv.next(r);
  (match row1{
    ok(row){
      (test.eq(row.fields.get(1);"10"));
    };
    err(e){
      (test.fail(e.msg));
    };
  });
  <true
};


f=tsvparse():bool{
  let data=str.bytes("a	b	c
1	2	3
");
  let r=csv.reader(data;9);
  let hdrresult=csv.header(r);
  (match hdrresult{
    ok(h){
      (test.eq(h.len;3));
      (test.eq(h.get(2);"c"));
    };
    err(e){
      (test.fail(e.msg));
    };
  });
  <true
};

f=main():i64{
  (test.ok(roundtrip()));
  (test.ok(streaming()));
  (test.ok(tsvparse()));
  <0
};
