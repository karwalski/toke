m=template_test;
i=tpl:std.template;
i=str:std.str;
i=test:std.test;

(* Render a full HTML page using tpl.compile + tpl.render *)
f=test_full_page():bool{
  let page_tmpl="<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><title>{{title}}</title><style>body{font-family:sans-serif;margin:2rem}h1{color:#333}.nav a{margin-right:1rem}</style></head><body><header><nav class=\"nav\">{{nav}}</nav></header><main><h1>{{heading}}</h1><p>{{intro}}</p>{{content}}</main><footer><p>{{footer}}</p></footer></body></html>";
  let t=tpl.compile(page_tmpl)!$tpl.$tmplerr;
  let nav=tpl.html("a";@("href":"/";  "class":"nav-link");@("Home"));
  let nav2=tpl.html("a";@("href":"/about";"class":"nav-link");@("About"));
  let nav_html=str.concat(nav;nav2);
  let ul_items=tpl.html("li";@();@("Item one"));
  let ul_items2=tpl.html("li";@();@("Item two"));
  let ul_items3=tpl.html("li";@();@("Item three"));
  let all_items=str.concat(str.concat(ul_items;ul_items2);ul_items3);
  let ul=tpl.html("ul";@();@(all_items));
  let v=tpl.vars(@(
    "title":"My toke Page";
    "nav":nav_html;
    "heading":"Welcome";
    "intro":"This page was generated by std.template in toke.";
    "content":ul;
    "footer":"&copy; 2026 toke project"
  ));
  let out=tpl.render(t;v)!$tpl.$tmplerr;
  <str.contains(out;"<!DOCTYPE html>")&&str.contains(out;"My toke Page")&&str.contains(out;"Welcome")&&str.contains(out;"Item one")
};

(* HTML escaping prevents XSS *)
f=test_escape():bool{
  let raw="<script>alert(\"xss\")</script>";
  let escaped=tpl.escape(raw);
  <str.contains(escaped;"&lt;script&gt;")&&!str.contains(escaped;"<script>")
};

(* tpl.html constructs an anchor element *)
f=test_html_element():bool{
  let el=tpl.html("a";@("href":"https://example.com";"target":"_blank");@("Click here"));
  <str.contains(el;"<a ")&&str.contains(el;"href=\"https://example.com\"")&&str.contains(el;"Click here")&&str.contains(el;"</a>")
};

(* tpl.html void element (no children) *)
f=test_html_void():bool{
  let img=tpl.html("img";@("src":"/logo.png";"alt":"Logo");@());
  <str.contains(img;"<img ")&&str.contains(img;"src=\"/logo.png\"")&&str.contains(img;"alt=\"Logo\"")
};

(* tpl.vars constructs a valid tmplvars *)
f=test_vars():bool{
  let t=tpl.compile("Hello {{name}}!")!$tpl.$tmplerr;
  let v=tpl.vars(@("name":"World"));
  let out=tpl.render(t;v)!$tpl.$tmplerr;
  <out=="Hello World!"
};

(* Unmatched slot returns tmplerr *)
f=test_missing_var():bool{
  let t=tpl.compile("{{greeting}} {{name}}")!$tpl.$tmplerr;
  let v=tpl.vars(@("greeting":"Hi"));
  let result=tpl.render(t;v);
  (match result{
    ok(s){<false};
    err(e){<true};
  })
};

(* Multiple render calls with same compiled template *)
f=test_multi_render():bool{
  let t=tpl.compile("<li>{{item}}</li>")!$tpl.$tmplerr;
  let r1=tpl.render(t;tpl.vars(@("item":"Alpha")))!$tpl.$tmplerr;
  let r2=tpl.render(t;tpl.vars(@("item":"Beta")))!$tpl.$tmplerr;
  let r3=tpl.render(t;tpl.vars(@("item":"Gamma")))!$tpl.$tmplerr;
  <str.contains(r1;"Alpha")&&str.contains(r2;"Beta")&&str.contains(r3;"Gamma")
};

(* Inline CSS generation using nested tpl.html calls *)
f=test_css_inline():bool{
  let style_content="body{margin:0}h1{font-size:2rem}";
  let style_el=tpl.html("style";@();@(style_content));
  <str.contains(style_el;"<style>")&&str.contains(style_el;"font-size")
};

(* Inline JS generation via template *)
f=test_js_template():bool{
  let js_tmpl="(function(){var app={{appvar}};app.init();})();";
  let t=tpl.compile(js_tmpl)!$tpl.$tmplerr;
  let v=tpl.vars(@("appvar":"{name:\"toke\"}"));
  let out=tpl.render(t;v)!$tpl.$tmplerr;
  <str.contains(out;"app.init()")&&str.contains(out;"toke")
};

f=main():i64{
  let r0=test_full_page();
  let r1=test_escape();
  let r2=test_html_element();
  let r3=test_html_void();
  let r4=test_vars();
  let r5=test_missing_var();
  let r6=test_multi_render();
  let r7=test_css_inline();
  let r8=test_js_template();
  if(r0&&r1&&r2&&r3&&r4&&r5&&r6&&r7&&r8){
    <0
  }el{
    <1
  }
};
