m=templatetest;
i=tpl:std.template;
i=str:std.str;
i=test:std.test;


f=testfullpage():bool{
  let pagetmpl="<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><title>{{title}}</title><style>body{font-family:sans-serif;margin:2rem}h1{color:#333}.nav a{margin-right:1rem}</style></head><body><header><nav class=\"nav\">{{nav}}</nav></header><main><h1>{{heading}}</h1><p>{{intro}}</p>{{content}}</main><footer><p>{{footer}}</p></footer></body></html>";
  let t=$tpl.compile(pagetmpl)!i64$tmplerr;
  let nav=tpl.html("a";@("href":"/";  "class":"nav-link");@("Home"));
  let nav2=tpl.html("a";@("href":"/about";"class":"nav-link");@("About"));
  let navhtml=str.concat(nav;nav2);
  let ulitems=tpl.html("li";@();@("Item one"));
  let ulitems2=tpl.html("li";@();@("Item two"));
  let ulitems3=tpl.html("li";@();@("Item three"));
  let allitems=str.concat(str.concat(ulitems;ulitems2);ulitems3);
  let ul=tpl.html("ul";@();@($allitems));
  let v=tpl.vars(@(
    "title":"My toke Page";
    "nav":navhtml;
    "heading":"Welcome";
    "intro":"This page was generated by std.template in toke.";
    "content":ul;
    "footer":"&copy; 2026 toke project"
  ));
  let out=tpl.render(t;v)!i64$tmplerr;
  <str.contains(out;"<!DOCTYPE html>")&&str.contains(out;"My toke Page")&&str.contains(out;"Welcome")&&str.contains(out;"Item one")
};


f=testescape():bool{
  let raw="<script>alert(\"xss\")</script>";
  let escaped=tpl.escape(raw);
  <str.contains(escaped;"&lt;script&gt;")&&!str.contains(escaped;"<script>")
};


f=testhtmlelement():bool{
  let el=tpl.html("a";@("href":"https://example.com";"target":"_blank");@("Click here"));
  <str.contains(el;"<a ")&&str.contains(el;"href=\"https://example.com\"")&&str.contains(el;"Click here")&&str.contains(el;"</a>")
};


f=testhtmlvoid():bool{
  let img=tpl.html("img";@("src":"/logo.png";"alt":"Logo");@());
  <str.contains(img;"<img ")&&str.contains(img;"src=\"/logo.png\"")&&str.contains(img;"alt=\"Logo\"")
};


f=testvars():bool{
  let t=$tpl.compile("Hello {{name}}!")!i64$tmplerr;
  let v=tpl.vars(@("name":"World"));
  let out=tpl.render(t;v)!i64$tmplerr;
  <out="Hello World!"
};


f=testmissingvar():bool{
  let t=$tpl.compile("{{greeting}} {{name}}")!i64$tmplerr;
  let v=tpl.vars(@("greeting":"Hi"));
  let result=tpl.render(t;v);
  (match result{
    ok(s){<false};
    err(e){<true};
  })
};


f=testmultirender():bool{
  let t=$tpl.compile("<li>{{item}}</li>")!i64$tmplerr;
  let r1=tpl.render(t;tpl.vars(@("item":"Alpha")))!i64$tmplerr;
  let r2=tpl.render(t;tpl.vars(@("item":"Beta")))!i64$tmplerr;
  let r3=tpl.render(t;tpl.vars(@("item":"Gamma")))!i64$tmplerr;
  <str.contains(r1;"Alpha")&&str.contains(r2;"Beta")&&str.contains(r3;"Gamma")
};


f=testcssinline():bool{
  let stylecontent="body{margin:0}h1{font-size:2rem}";
  let styleel=tpl.html("style";@();@($stylecontent));
  <str.contains(styleel;"<style>")&&str.contains(styleel;"font-size")
};


f=testjstemplate():bool{
  let jstmpl="(function(){var app={{appvar}};app.init();})();";
  let t=$tpl.compile(jstmpl)!i64$tmplerr;
  let v=tpl.vars(@("appvar":"{name:\"toke\"}"));
  let out=tpl.render(t;v)!i64$tmplerr;
  <str.contains(out;"app.init()")&&str.contains(out;"toke")
};

f=main():i64{
  let r0=testfullpage();
  let r1=testescape();
  let r2=testhtmlelement();
  let r3=testhtmlvoid();
  let r4=testvars();
  let r5=testmissingvar();
  let r6=testmultirender();
  let r7=testcssinline();
  let r8=testjstemplate();
  if(r0&&r1&&r2&&r3&&r4&&r5&&r6&&r7&&r8){
    <0
  }el{
    <1
  }
};
