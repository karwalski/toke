m=mltest;
i=ml:std.ml;
i=test:std.test;


f=linregfitpredict():bool{
  let xtrain=@(
    $row{vals:@(0.0)};
    $row{vals:@(1.0)};
    $row{vals:@(2.0)};
    $row{vals:@(3.0)};
    $row{vals:@(4.0)}
  );
  let ytrain=@(0.0;2.0;4.0;6.0;8.0);
  let fitresult=ml.linregfit(xtrain;ytrain);
  (match fitresult{
    ok(model){
      let pred=ml.linregpredict(model;@(5.0));
      let diff=pred-10.0;
      let absdiff=if diff<0.0{<(-diff);}el{<diff;};
      <(absdiff<0.01)
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=kmeanstwoclusters():bool{
  let data=@(
    $row{vals:@(0.0;0.0)};
    $row{vals:@(0.1;0.1)};
    $row{vals:@(0.2;0.0)};
    $row{vals:@(10.0;10.0)};
    $row{vals:@(10.1;9.9)};
    $row{vals:@(9.9;10.1)}
  );
  let fitresult=ml.kmeanstrain(data;2;100);
  (match fitresult{
    ok(model){
      (test.eq(model.k;2));
      let c0=ml.kmeansassign(model;@(0.0;0.0));
      let c1=ml.kmeansassign(model;@(10.0;10.0));
      
      <(!(c0=c1))
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};


f=knnclassify():bool{
  let trainx=@(
    $row{vals:@(1.0)};
    $row{vals:@(2.0)};
    $row{vals:@(8.0)};
    $row{vals:@(9.0)}
  );
  let trainy=@("low";"low";"high";"high");
  let label=ml.knnpredict(trainx;trainy;@(1.5);1);
  <(label="low")
};


f=dtreefitpredict():bool{
  let xtrain=@(
    $row{vals:@(0.0;0.0)};
    $row{vals:@(0.0;1.0)};
    $row{vals:@(1.0;0.0)};
    $row{vals:@(1.0;1.0)}
  );
  let ytrain=@("neg";"neg";"neg";"pos");
  let fitresult=ml.dtreefit(xtrain;ytrain;5);
  (match fitresult{
    ok(model){
      let label=ml.dtreepredict(model;@(1.0;1.0));
      <(label="pos")
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  })
};

f=main():i64{
  (test.ok(linregfitpredict()));
  (test.ok(kmeanstwoclusters()));
  (test.ok(knnclassify()));
  (test.ok(dtreefitpredict()));
  <0
};
