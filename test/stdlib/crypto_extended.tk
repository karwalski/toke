m=cryptoextendedtest;




f=hmacroundtrip():bool{
  let key=str.bytes("supersecretkey");
  let msg=str.bytes("user:alice;role:admin;exp:9999999999");
  let tag=crypto.hmacsha256(key;msg);
  let expectedlen:u64=32;
  (test.eq(tag.len;expectedlen));

  
  let tag2=crypto.hmacsha256(key;msg);
  <crypto.constanteq(tag;tag2)
};


f=hmac512len():bool{
  let key=str.bytes("anotherkey");
  let msg=str.bytes("payload");
  let tag=crypto.hmacsha512(key;msg);
  let expectedlen:u64=64;
  (test.eq(tag.len;expectedlen));
  <true
};


f=sha256empty():bool{
  let hash=crypto.sha256(@());
  let hex=crypto.tohex(hash);
  <hex="e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
};


f=sha512len():bool{
  let hash=crypto.sha512(str.bytes("abc"));
  let expectedlen:u64=64;
  (test.eq(hash.len;expectedlen));
  <true
};


f=constanteqtamper():bool{
  let key=str.bytes("k");
  let msg=str.bytes("msg");
  let tag=crypto.hmacsha256(key;msg);
  let badmsg=str.bytes("msg-tampered");
  let badtag=crypto.hmacsha256(key;badmsg);
  <(!$crypto.constanteq(tag;badtag))
};


f=randomlen():bool{
  let n:u64=32;
  let rand=crypto.randombytes(n);
  (test.eq(rand.len;n));
  <true
};

f=main():i64{
  (test.ok(hmacroundtrip()));
  (test.ok(hmac512len()));
  (test.ok(sha256empty()));
  (test.ok(sha512len()));
  (test.ok(constanteqtamper()));
  (test.ok(randomlen()));
  <0
};
