m=testimage;
i=image:std.image;
i=test:std.test;


f=make2x2():imgbuf{
  
  let data=@(
    255;0;0;255;    
    0;255;0;255;    
    0;0;255;255;    
    255;255;0;255   
  );
  let w:u32=2;
  let h:u32=2;
  let ch:u8=4;
  <image.fromraw(data;w;h;ch)
};


f=testfromraw():bool{
  let buf=make2x2();
  let expectedw:u32=2;
  let expectedh:u32=2;
  let expectedch:u8=4;
  let expectedlen:u64=16;
  (test.eq(buf.width;expectedw));
  (test.eq(buf.height;expectedh));
  (test.eq(buf.channels;expectedch));
  (test.eq(buf.data.len;expectedlen));
  <true
};


f=testpixelatcorners():bool{
  let buf=make2x2();

  let tl=image.pixelat(buf;0;0);
  (match tl{
    ok(px){
      let expectedr:u8=255;
      let expectedg:u8=0;
      (test.eq(px.0;expectedr));
      (test.eq(px.1;expectedg));
    };
    err(msg){ (test.fail(msg)); };
  });

  let tr=image.pixelat(buf;1;0);
  (match tr{
    ok(px){
      let expectedg:u8=255;
      (test.eq(px.1;expectedg));
    };
    err(msg){ (test.fail(msg)); };
  });

  <true
};


f=testpixelatoob():bool{
  let buf=make2x2();
  let result=image.pixelat(buf;5;5);
  (match result{
    ok(){ (test.fail("expected error for oob pixel")); <false };
    err(){ <true };
  })
};


f=testresize():bool{
  let buf=make2x2();
  let resized=image.resize(buf;8;8);
  let expectedw:u32=8;
  let expectedh:u32=8;
  let expectedlen:u64=256;   
  (test.eq(resized.width;expectedw));
  (test.eq(resized.height;expectedh));
  (test.eq(resized.data.len;expectedlen));
  <true
};


f=testcropvalid():bool{
  let buf=image.fromraw(
    @(
      10;20;30;255; 40;50;60;255; 70;80;90;255; 100;110;120;255;
      11;21;31;255; 41;51;61;255; 71;81;91;255; 101;111;121;255;
      12;22;32;255; 42;52;62;255; 72;82;92;255; 102;112;122;255;
      13;23;33;255; 43;53;63;255; 73;83;93;255; 103;113;123;255
    );
    4;4;4
  );
  let result=image.crop(buf;1;1;2;2);
  (match result{
    ok(cropped){
      let expectedw:u32=2;
      let expectedh:u32=2;
      let expectedlen:u64=16;
      (test.eq(cropped.width;expectedw));
      (test.eq(cropped.height;expectedh));
      (test.eq(cropped.data.len;expectedlen));
      <true
    };
    err(msg){ (test.fail(msg)); <false };
  })
};


f=testcropoob():bool{
  let buf=make2x2();
  let result=image.crop(buf;1;1;5;5);
  (match result{
    ok(){ (test.fail("expected oob error")); <false };
    err(){ <true };
  })
};


f=testtograyscale():bool{
  let buf=make2x2();
  let gray=image.tograyscale(buf);
  let expectedch:u8=1;
  let expectedlen:u64=4;   
  (test.eq(gray.channels;expectedch));
  (test.eq(gray.width;buf.width));
  (test.eq(gray.height;buf.height));
  (test.eq(gray.data.len;expectedlen));
  <true
};


f=testfliphdims():bool{
  let buf=make2x2();
  let flipped=image.fliph(buf);
  (test.eq(flipped.width;buf.width));
  (test.eq(flipped.height;buf.height));
  (test.eq(flipped.channels;buf.channels));
  <true
};


f=testfliphpixels():bool{
  let buf=make2x2();
  
  let pxresult=image.pixelat((image.fliph(buf));0;0);
  (match pxresult{
    ok(px){
      let expectedr:u8=0;
      let expectedg:u8=255;
      (test.eq(px.0;expectedr));
      (test.eq(px.1;expectedg));
      <true
    };
    err(msg){ (test.fail(msg)); <false };
  })
};


f=testflipvdims():bool{
  let buf=make2x2();
  let flipped=image.flipv(buf);
  (test.eq(flipped.width;buf.width));
  (test.eq(flipped.height;buf.height));
  (test.eq(flipped.channels;buf.channels));
  <true
};


f=testflipvpixels():bool{
  let buf=make2x2();
  
  let pxresult=image.pixelat((image.flipv(buf));0;0);
  (match pxresult{
    ok(px){
      let expectedr:u8=0;
      let expectedb:u8=255;
      (test.eq(px.0;expectedr));
      (test.eq(px.2;expectedb));
      <true
    };
    err(msg){ (test.fail(msg)); <false };
  })
};


f=testencodedecodepng():bool{
  let buf=make2x2();
  let encresult=image.encode(buf;$$png;0);
  (match encresult{
    ok(pngbytes){
      let decresult=image.decode(pngbytes);
      (match decresult{
        ok(decoded){
          (test.eq(decoded.width;buf.width));
          (test.eq(decoded.height;buf.height));
          (test.eq(decoded.channels;buf.channels));
          <true
        };
        err(msg){ (test.fail("decode failed: " ++ msg)); <false };
      })
    };
    err(msg){ (test.fail("encode failed: " ++ msg)); <false };
  })
};


f=testencodedecodejpeg():bool{
  let buf=make2x2();
  
  let encresult=image.encode(buf;$$jpeg;90);
  (match encresult{
    ok(jpegbytes){
      let decresult=image.decode(jpegbytes);
      (match decresult{
        ok(decoded){
          (test.eq(decoded.width;buf.width));
          (test.eq(decoded.height;buf.height));
          <true
        };
        err(msg){ (test.fail("jpeg decode failed: " ++ msg)); <false };
      })
    };
    err(msg){ (test.fail("jpeg encode failed: " ++ msg)); <false };
  })
};


f=testdecodebadbytes():bool{
  let garbage=@(0;1;2;3;4;5;6;7);
  let result=image.decode(garbage);
  (match result{
    ok(){ (test.fail("expected decode error for garbage bytes")); <false };
    err(){ <true };
  })
};

f=main():i64{
  (test.ok(testfromraw()));
  (test.ok(testpixelatcorners()));
  (test.ok(testpixelatoob()));
  (test.ok(testresize()));
  (test.ok(testcropvalid()));
  (test.ok(testcropoob()));
  (test.ok(testtograyscale()));
  (test.ok(testfliphdims()));
  (test.ok(testfliphpixels()));
  (test.ok(testflipvdims()));
  (test.ok(testflipvpixels()));
  (test.ok(testencodedecodepng()));
  (test.ok(testencodedecodejpeg()));
  (test.ok(testdecodebadbytes()));
  <0
};
