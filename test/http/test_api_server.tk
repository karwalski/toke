m=testapi;
i=http:std.http;
i=json:std.json;
i=str:std.str;
i=io:std.io;



f=main():i64{
  http.getstatic("/api/ping"; "{\"status\":\"ok\"}");

  http.get("/api/echo"; &handlerecho);
  http.post("/api/echo"; &handlerechopost);
  http.put("/api/data"; &handlerput);
  http.delete("/api/data"; &handlerdelete);
  http.get("/api/headers"; &handlerheaders);
  http.post("/api/form"; &handlerform);
  http.get("/api/stream"; &handlerstream);
  http.get("/api/auth"; &handlerauth);
  http.get("/api/status/:code"; &handlerstatus);

  io.println("Test API server listening on :8099");
  http.serve(8099);
  <0
};

f=handlerecho(req:$req):$res{
  let msg=http.queryparam(req; "msg");
  let body=str.concat("{\"echo\":\""; str.concat(msg; "\"}"));
  <http.jsonresp(200; body)
};

f=handlerechopost(req:$req):$res{
  let body=http.body(req);
  let resp=str.concat("{\"echo\":"; str.concat(json.stringify(body); "}"));
  <http.jsonresp(200; resp)
};

f=handlerput(req:$req):$res{
  let body=http.body(req);
  let resp=str.concat("{\"method\":\"PUT\",\"body\":"; str.concat(json.stringify(body); "}"));
  <http.jsonresp(200; resp)
};

f=handlerdelete(req:$req):$res{
  <http.jsonresp(200; "{\"method\":\"DELETE\",\"deleted\":true}")
};

f=handlerheaders(req:$req):$res{
  let hdrs=http.headers(req);
  <http.jsonresp(200; json.stringify(hdrs))
};

f=handlerform(req:$req):$res{
  let body=http.body(req);
  <http.jsonresp(200; str.concat("{\"form_data\":"; str.concat(json.stringify(body); "}")))
};

f=handlerstream(req:$req):$res{
  let lines=@("line 1
"; "line 2
"; "line 3
"; "line 4
"; "line 5
");
  let body=str.join(lines; "");
  <http.resp(200; body; "text/plain")
};

f=handlerauth(req:$req):$res{
  let auth=http.header(req; "authorization");
  if(str.len(auth) = 0){
    <http.resp(401; "{\"error\":\"unauthorized\"}"; "application/json")
  };
  <http.jsonresp(200; str.concat("{\"auth\":"; str.concat(json.stringify(auth); "}")))
};

f=handlerstatus(req:$req):$res{
  let code=http.param(req; "code");
  let status=str.toint(code);
  <http.resp(status; str.concat("{\"status\":"; str.concat(code; "}")); "application/json")
};
