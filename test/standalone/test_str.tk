m=teststr;
i=str:std.str;
i=io:std.io;
f=main():i64{
  if(str.eq("a";"a")){io.println("PASS str.eq same")}el{io.println("FAIL str.eq same")};
  if(str.eq("a";"b")){io.println("FAIL str.eq diff")}el{io.println("PASS str.eq diff")};
  if(str.eq("";"")) {io.println("PASS str.eq empty")}el{io.println("FAIL str.eq empty")};
  let c=str.concat("hello";" world");
  if(str.eq(c;"hello world")){io.println("PASS str.concat")}el{io.println("FAIL str.concat")};
  if(str.len("hello")=5){io.println("PASS str.len")}el{io.println("FAIL str.len")};
  if(str.len("")=0){io.println("PASS str.len empty")}el{io.println("FAIL str.len empty")};
  if(str.contains("hello world";"world")){io.println("PASS str.contains found")}el{io.println("FAIL str.contains found")};
  if(str.contains("hello";"xyz")){io.println("FAIL str.contains notfound")}el{io.println("PASS str.contains notfound")};
  let parts=str.split("a,b,c";",");
  let first=parts.get(0);
  if(str.eq(first;"a")){io.println("PASS str.split first")}el{io.println("FAIL str.split first")};
  let trimmed=str.trim("  hi  ");
  if(str.eq(trimmed;"hi")){io.println("PASS str.trim")}el{io.println("FAIL str.trim")};
  let up=str.upper("hello");
  if(str.eq(up;"HELLO")){io.println("PASS str.upper")}el{io.println("FAIL str.upper")};
  let lo=str.lower("HELLO");
  if(str.eq(lo;"hello")){io.println("PASS str.lower")}el{io.println("FAIL str.lower")};
  if(str.startswith("hello";"hel")){io.println("PASS str.startswith")}el{io.println("FAIL str.startswith")};
  if(str.endswith("hello";"llo")){io.println("PASS str.endswith")}el{io.println("FAIL str.endswith")};
  let rep=str.repeat("ab";3);
  if(str.eq(rep;"ababab")){io.println("PASS str.repeat")}el{io.println("FAIL str.repeat")};
  let rev=str.reverse("abcd");
  if(str.eq(rev;"dcba")){io.println("PASS str.reverse")}el{io.println("FAIL str.reverse")};
  let fi=str.fromint(42);
  if(str.eq(fi;"42")){io.println("PASS str.fromint")}el{io.println("FAIL str.fromint")};
  let ff=str.fromfloat(3.14);
  if(str.isempty(ff)){io.println("FAIL str.fromfloat")}el{io.println("PASS str.fromfloat")};
  let ti=str.toint("99");
  if(ti=99){io.println("PASS str.toint")}el{io.println("FAIL str.toint")};
  if(str.isempty("")){io.println("PASS str.isempty true")}el{io.println("FAIL str.isempty true")};
  if(str.isempty("x")){io.println("FAIL str.isempty false")}el{io.println("PASS str.isempty false")};
  let rp=str.replace("hello";"l";"r");
  if(str.eq(rp;"herro")){io.println("PASS str.replace")}el{io.println("FAIL str.replace")};
  let sl=str.slice("hello";1;4);
  if(str.eq(sl;"ell")){io.println("PASS str.slice")}el{io.println("FAIL str.slice")};
  let idx=str.indexof("hello world";"world");
  if(idx=6){io.println("PASS str.indexof")}el{io.println("FAIL str.indexof")};
  let j=str.join(@("a";"b";"c");",");
  if(str.eq(j;"a,b,c")){io.println("PASS str.join")}el{io.println("FAIL str.join")};
  let pl=str.padleft("hi";5;48);
  if(str.eq(pl;"000hi")){io.println("PASS str.padleft")}el{io.println("FAIL str.padleft")};
  let pr=str.padright("hi";5;48);
  if(str.eq(pr;"hi000")){io.println("PASS str.padright")}el{io.println("FAIL str.padright")};
  <0
};
