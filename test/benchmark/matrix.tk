m=benchmark.matrix;
i=io:std.io;
i=str:std.str;
i=time:std.time;




f=matidx(n:i64;r:i64;c:i64):i64{
  <r*n+c
};


f=matfilla(n:i64):@f64{
  let m=mut.@();
  lp(let i=0;i<n*n;i=i+1){
    let r=i/n;
    let c=i-r*n;
    let v=(r as f64)*0.5+(c as f64)*0.3+1.0;
    m=m.push(v);
  };
  <m
};


f=matfillb(n:i64):@f64{
  let m=mut.@();
  lp(let i=0;i<n*n;i=i+1){
    let r=i/n;
    let c=i-r*n;
    let v=(c as f64)*0.7-(r as f64)*0.2+2.0;
    m=m.push(v);
  };
  <m
};


f=matmul(a:@f64;b:@f64;n:i64):@f64{
  let c=mut.@();
  lp(let r=0;r<n;r=r+1){
    lp(let col=0;col<n;col=col+1){
      let sum=mut.0.0;
      lp(let k=0;k<n;k=k+1){
        sum=sum+a.get(matidx(n;r;k))*b.get(matidx(n;k;col))
      };
      c=c.push(sum)
    }
  };
  <c
};


f=checksum(m:@f64;n:i64):f64{
  let sum=mut.0.0;
  sum=sum+m.get(matidx(n;0;0));
  sum=sum+m.get(matidx(n;0;n-1));
  sum=sum+m.get(matidx(n;n-1;0));
  sum=sum+m.get(matidx(n;n-1;n-1));
  sum=sum+m.get(matidx(n;n/2;n/2));
  <sum
};


f=main():i64{
  let n=200;
  let iterations=3;

  io.println("benchmark: matrix multiplication");
  io.println(str.concat("  size: ";str.concat(str.fromint(n);str.concat("x";str.fromint(n)))));
  io.println(str.concat("  iterations: ";str.fromint(iterations)));

  let a=matfilla(n);
  let b=matfillb(n);

  let t0=time.now();
  let result=mut.matmul(a;b;n);
  lp(let run=1;run<iterations;run=run+1){
    result=matmul(a;b;n)
  };
  let t1=time.now();
  let elapsed=t1-t0;

  let ck=checksum(result;n);

  io.println("");
  io.println(str.concat("  checksum:    ";str.fromfloat(ck)));
  io.println(str.concat("  elapsed (s): ";str.fromint(elapsed)));
  io.println("");
  io.println("  (compare checksum against c/rust reference)");

  
  if(ck>0.0){<1}el{<0}
};
